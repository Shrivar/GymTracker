SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-cloud-run-url.run.app

# Database
USE_CLOUD_SQL_SOCKET=False
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-password
DB_NAME=gymtracker

# Or for Cloud SQL:
# USE_CLOUD_SQL_SOCKET=True
# CLOUD_SQL_CONNECTION_NAME=project:region:instance
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_NAME=gymtracker

# Google OAuth (from Google Cloud Console)
SOCIALACCOUNT_PROVIDERS_GOOGLE_APP_ID=your-app-id.apps.googleusercontent.com
SOCIALACCOUNT_PROVIDERS_GOOGLE_APP_SECRET=your-app-secret

