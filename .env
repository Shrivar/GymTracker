SECRET_KEY=dev-secret-key-for-local-development
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database - local PostgreSQL
USE_CLOUD_SQL_SOCKET=False
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=gymtracker

# Google OAuth (get these from Google Cloud Console)
SOCIALACCOUNT_PROVIDERS_GOOGLE_APP_ID=your-app-id.apps.googleusercontent.com
SOCIALACCOUNT_PROVIDERS_GOOGLE_APP_SECRET=your-app-secret

